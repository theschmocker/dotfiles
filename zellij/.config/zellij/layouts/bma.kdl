layout {
	cwd "~/BlainsMobileApp"
	default_tab_template {
		pane size=1 borderless=true {
			plugin location="tab-bar"
		}
		children
		pane size=1 borderless=true {
			plugin location="status-bar"
		}
	}

	tab name="nvim" {
		pane {
			command "nvim"
			start_suspended false
		}
	}

	tab name="metro" {
		pane
	}
	tab name="run" split_direction="vertical" {
		pane
		pane
	}
}
